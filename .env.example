# Copy to .env (or .env.local) and fill in. See setup.txt for full instructions.

# --- Database (matches docker-compose.yml) ---
DATABASE_URL="postgresql://reporadar:reporadar@localhost:5432/reporadar?schema=public"

# --- GitHub ---
# Personal Access Token (classic) with read-only public scope, to lift the
# GitHub Search/REST rate limits. Create at:
# github.com -> Settings -> Developer settings -> Personal access tokens.
GITHUB_TOKEN=""

# --- LLM via OpenRouter ---
# THIS is the LLM API key. Get it at https://openrouter.ai -> Keys.
# Note: OpenRouter top-up is card/crypto, not WeChat/Alipay.
OPENROUTER_API_KEY=""
# Any OpenRouter chat model slug. Default is a cheap DeepSeek model.
OPENROUTER_MODEL="deepseek/deepseek-chat"

# Set "true" to run the whole app with NO paid services (deterministic funnel
# ordering only, no AI scores). Set "false" once OPENROUTER_API_KEY is set.
NO_LLM_MODE="true"

# Number of funnel survivors the AI scores per search (<= 20 for cost control).
FUNNEL_TOP_N="15"

# Embeddings are LOCAL and FREE (Transformers.js, all-MiniLM-L6-v2). No key needed.

# Optional: set to "true" only if the project is stored on an exFAT drive.
# Normal NTFS/Linux/macOS filesystems should leave this unset/false so Next can
# use its standard development cache and manifests.
REPORADAR_EXFAT_MODE="false"
