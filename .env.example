# ─────────────────────────────────────────────────────────────────────────────
# RepoRadar — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env (it is already in .gitignore).
# Set all of these in the Railway dashboard for production deployments.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string with pgvector extension enabled.
# Railway provides this automatically when you add a Postgres plugin.
DATABASE_URL="postgresql://reporadar:reporadar@localhost:5432/reporadar?schema=public"

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal Access Token (classic) with read:public_repo scope.
# Lifts GitHub Search + REST + GraphQL rate limits from 60 → 5000 req/h.
# Create at: github.com → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=""

# ── LLM via OpenRouter ───────────────────────────────────────────────────────
# API key from https://openrouter.ai → Keys
OPENROUTER_API_KEY=""

# Model used for scoring + explanation. Cheap and fast is best here.
# google/gemini-2.5-flash-lite gives good quality at ~$0.10/$0.40 per M tokens.
OPENROUTER_MODEL="google/gemini-2.5-flash-lite"

# Model used for intent extraction (can differ from scoring model).
# Leave empty to use OPENROUTER_MODEL for both.
INTENT_MODEL="google/gemini-2.5-flash-lite"

# ── Feature flags ────────────────────────────────────────────────────────────
# Set "true" to disable all LLM calls (deterministic funnel only, free to run).
# Set "false" once OPENROUTER_API_KEY is configured.
NO_LLM_MODE="false"

# ── Tuning ───────────────────────────────────────────────────────────────────
# Maximum candidates fetched from GitHub (keep ≤ 80 to avoid ONNX blocking).
MAX_CANDIDATES="80"

# Top N funnel survivors that get LLM scoring (cost control).
FUNNEL_TOP_N="15"

# How many of the FUNNEL_TOP_N are LLM-scored (rest get deterministic scores).
LLM_SCORE_TOP_N="10"

# Number of GitHub search queries executed per search (6–8 recommended for open recall).
MAX_SEARCH_QUERIES="6"

# Number of raw candidates that get cheap README-head enrichment before the funnel.
# Keep this around 20 so fresh searches stay under one minute.
LIGHT_ENRICH_TOP_N="20"

# LLM call timeout in milliseconds. 16000ms covers most cold model starts.
LLM_TIMEOUT_MS="16000"

# Intent extraction has heuristic/guidance fallback, so keep its timeout tighter.
INTENT_TIMEOUT_MS="6000"

# Separate timeout for the single listwise ranking pass. If it times out,
# RepoRadar falls back to the existing pointwise/deterministic scorer.
LISTWISE_TIMEOUT_MS="10000"

# Calibrated cold-search duration shown by the progress bar (seconds).
SEARCH_ETA_SECONDS="67"

# Establishment prior in final ranking. A log-scaled popularity term breaks ties
# toward proven repos when relevance is comparable (MiniLM similarity is too
# compressed to separate the canonical library from an obscure keyword match).
# It is relevance-gated (no lift for irrelevant repos) and capped low so strong
# small repos still surface. 0 = pure relevance; 0.25 = balanced default.
POPULARITY_WEIGHT="0.25"

# ── Local development only ───────────────────────────────────────────────────
# Set "true" ONLY if the project is on an exFAT drive (e.g. removable USB).
# Leave unset or "false" on NTFS / Linux / macOS.
REPORADAR_EXFAT_MODE="false"
